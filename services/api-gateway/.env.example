# Runtime
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# Downstream services
AUTH_SERVICE_URL=http://auth-service:8080
EVENT_SERVICE_URL=http://event-service:8080
TICKET_SERVICE_URL=http://ticket-service:8080
ORDER_SERVICE_URL=http://order-service:8080
PAYMENT_SERVICE_URL=http://payment-service:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8080
CHECKIN_SERVICE_URL=http://checkin-service:8080
INVENTORY_SERVICE_URL=http://inventory-service:8080
AI_BIO_SERVICE_URL=http://ai-bio-service:8080
CSV_INGESTION_SERVICE_URL=http://csv-ingestion-service:8080

# JWT verification
JWT_PUBLIC_KEY_PATH=/keys/public.pem
JWT_ISSUER=tickefy-auth-service
JWT_AUDIENCE=tickefy-api

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_MAX_AGE_SECONDS=3600

# Redis
REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT=500ms
REDIS_COMMAND_TIMEOUT=500ms

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
RATE_LIMIT_RETRY_AFTER_SECONDS=1

RATE_LIMIT_DEFAULT_REPLENISH_RATE=20
RATE_LIMIT_DEFAULT_BURST_CAPACITY=40

RATE_LIMIT_AUTH_REPLENISH_RATE=5
RATE_LIMIT_AUTH_BURST_CAPACITY=10

RATE_LIMIT_PURCHASE_REPLENISH_RATE=2
RATE_LIMIT_PURCHASE_BURST_CAPACITY=4

# Gateway timeouts
GATEWAY_CONNECT_TIMEOUT_MS=2000
GATEWAY_RESPONSE_TIMEOUT=15s
GATEWAY_RESPONSE_TIMEOUT_MS=15000
GATEWAY_CHECKIN_RESPONSE_TIMEOUT_MS=5000
GATEWAY_UPLOAD_RESPONSE_TIMEOUT_MS=60000

# Gateway upload transport limits
AI_BIO_GATEWAY_MAX_REQUEST_SIZE=30MB
CSV_GATEWAY_MAX_REQUEST_SIZE=12MB