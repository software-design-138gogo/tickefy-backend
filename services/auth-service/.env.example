SPRING_PROFILES_ACTIVE=dev
SERVICE_NAME=auth-service
SERVER_PORT=8081
APP_TIMEZONE=UTC
TZ=UTC

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tickefy
DB_USERNAME=tickefy
DB_PASSWORD=change_me
DB_SCHEMA=auth_service

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=tickefy
RABBITMQ_PASSWORD=change_me

LOG_LEVEL=INFO

JWT_PRIVATE_KEY_PATH=classpath:keys/jwt-dev-private.pem
JWT_PUBLIC_KEY_PATH=classpath:keys/jwt-dev-public.pem
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P7D
BCRYPT_STRENGTH=10

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=System Admin

# Cookie auth (FE web). Access cookie is forward-looking (prod-via-gateway); refresh cookie (HttpOnly) is the primary security feature.
COOKIE_ACCESS_NAME=access_token
COOKIE_REFRESH_NAME=refresh_token
COOKIE_REFRESH_PATH=/auth
COOKIE_SECURE=false          # dev http://localhost; prod=true
COOKIE_SAMESITE=Lax          # None if FE is cross-site with API (then COOKIE_SECURE must be true)

# CORS allowlist (credentialed). Blank in prod = gateway owns CORS (api-contracts §1). Never use *.
# dev: 3000=web, 5173=admin
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
