SPRING_PROFILES_ACTIVE=dev
SERVICE_NAME=e-ticket-service
SERVER_PORT=8087
APP_TIMEZONE=UTC
TZ=UTC
# JWT — RS256 verify-only (public key from auth-service)
# Do NOT use JWT_SECRET — auth-service signs with RS256 private key
JWT_PUBLIC_KEY_PATH=classpath:keys/jwt-dev-public.pem
JWT_ISSUER=tickefy-auth-service
JWT_AUDIENCE=tickefy-api

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tickefy
DB_USERNAME=tickefy
DB_PASSWORD=change_me
DB_SCHEMA=eticket_service

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=tickefy
RABBITMQ_PASSWORD=change_me

LOG_LEVEL=INFO
